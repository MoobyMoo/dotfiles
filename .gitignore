# Lazy lock file (regenerated per system)
nvim/lazy-lock.json

# LSP and runtime files
nvim/.repro

# Local state
nvim/.netrwhist
*.swp
*.swo
*~
.DS_Store

# Tmux plugin manager
tmux/plugins/
tmux/resurrect/

# Fish shell
fish/fish_variables

# Omarchy
# Don't track dynamically generated theme files
omarchy/.config/omarchy/current/theme/preview.png
omarchy/.config/omarchy/current/theme/*.rgb
omarchy/.config/omarchy/current/theme/keyboard.rgb

# Don't track sample hooks (we track the actual hooks)
omarchy/.config/omarchy/hooks/*.sample

# Don't track theme templates
omarchy/.config/omarchy/themed/

# Alacritty/Kitty/Ghostty generated files
*/.cache/

# Generated/temporary files
misc/.config/uv/uv-receipt.json
misc/.config/yazi/*.md
misc/.config/yazi/*.tmTheme

# Plugin repositories (git submodules/cloned repos)
misc/.config/yazi-plugins/.git/
misc/.config/yazi-plugins/.github/

# LSP and cache directories
*/nvim/.repro
**/node_modules/
**/.cache/
**/__pycache__/

# Editor backups
*.swp
*.swo
*~

# System files
.DS_Store
Thumbs.db
