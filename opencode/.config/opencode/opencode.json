{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "google_workspace": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "google-workspace-mcp",
        "serve"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "google_tasks": {
      "type": "local",
      "command": [
        "/home/moo/.config/opencode/bin/google-tasks-mcp"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "browser": {
      "type": "local",
      "command": [
        "/home/moo/.config/opencode/bin/browser-mcp"
      ],
      "enabled": true,
      "timeout": 30000
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4"
    },
    "build": {
      "model": "openai/gpt-5.4"
    }
  }
}
