#!/usr/bin/env bash
set -euo pipefail

OUTPUT_FILE="${HOME}/.config/opencode/logs/student-brief-latest.md"
mkdir -p "$(dirname "${OUTPUT_FILE}")"

PROMPT="${*:-automated morning briefing}"

fish -c 'source ~/.config/fish/config.fish; ~/.config/opencode/bin/run-sync-student-vault pre-brief sync' >/dev/null
fish -c 'source ~/.config/fish/config.fish; ~/.config/opencode/bin/run-sync-deadlines-to-calendar pre-brief calendar sync' >/dev/null

BRIEF_OUTPUT="$(fish -c 'source ~/.config/fish/config.fish; opencode run --command student-brief --dir /home/moo --agent personal-admin --format default -- $argv' -- "${PROMPT}")"

printf '%s\n' "${BRIEF_OUTPUT}" > "${OUTPUT_FILE}"

fish -c 'source ~/.config/fish/config.fish; ~/.config/opencode/bin/run-auto-memory-sync post-brief sync' >/dev/null

if fish -c 'source ~/.config/fish/config.fish; test -n "$TELEGRAM_BOT_TOKEN"; and test -n "$TELEGRAM_CHAT_ID"'; then
  CLEAN_OUTPUT="$(printf '%s\n' "${BRIEF_OUTPUT}" | perl -pe 's/\e\[[0-9;]*m//g')"
  fish -c 'source ~/.config/fish/config.fish; ~/.config/opencode/bin/send-telegram "$argv[1]"' -- "${CLEAN_OUTPUT}"
fi

printf 'Student brief written to %s\n' "${OUTPUT_FILE}"
