#!/usr/bin/env node
const fs = require('fs')
const os = require('os')
const path = require('path')
const http = require('http')
const { execFile } = require('child_process')

const googleCredsPath = path.join(os.homedir(), '.google-mcp', 'credentials.json')
const tasksCredsPath = path.join(os.homedir(), '.config', 'mcp-googletasks-vrob', 'credentials.json')
const port = 3000
const redirectUri = `http://localhost:${port}/oauth2callback`
const scope = 'https://www.googleapis.com/auth/tasks'

if (!fs.existsSync(googleCredsPath)) {
  console.error(`Missing Google credentials: ${googleCredsPath}`)
  process.exit(1)
}

const creds = JSON.parse(fs.readFileSync(googleCredsPath, 'utf8'))
const installed = creds.installed || {}
const clientId = installed.client_id
const clientSecret = installed.client_secret

if (!clientId || !clientSecret) {
  console.error('Invalid Google desktop credentials file')
  process.exit(1)
}

const authUrl = new URL('https://accounts.google.com/o/oauth2/v2/auth')
authUrl.searchParams.set('access_type', 'offline')
authUrl.searchParams.set('scope', scope)
authUrl.searchParams.set('prompt', 'consent')
authUrl.searchParams.set('response_type', 'code')
authUrl.searchParams.set('client_id', clientId)
authUrl.searchParams.set('redirect_uri', redirectUri)

const server = http.createServer(async (req, res) => {
  try {
    const reqUrl = new URL(req.url, `http://localhost:${port}`)
    const code = reqUrl.searchParams.get('code')
    if (!code) {
      res.writeHead(400, { 'Content-Type': 'text/html; charset=utf-8' })
      res.end('<h1>No code received.</h1>')
      return
    }

    const body = new URLSearchParams({
      code,
      client_id: clientId,
      client_secret: clientSecret,
      redirect_uri: redirectUri,
      grant_type: 'authorization_code',
    })

    const tokenResp = await fetch('https://oauth2.googleapis.com/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body,
    })

    const tokenJson = await tokenResp.json()
    if (!tokenResp.ok) {
      res.writeHead(500, { 'Content-Type': 'text/html; charset=utf-8' })
      res.end(`<h1>Token exchange failed</h1><pre>${JSON.stringify(tokenJson, null, 2)}</pre>`)
      console.error('Token exchange failed:', tokenJson)
      return
    }

    const finalCreds = {
      access_token: tokenJson.access_token,
      refresh_token: tokenJson.refresh_token,
      scope: tokenJson.scope,
      token_type: tokenJson.token_type,
      expiry_date: Date.now() + tokenJson.expires_in * 1000,
    }

    fs.mkdirSync(path.dirname(tasksCredsPath), { recursive: true })
    fs.writeFileSync(tasksCredsPath, JSON.stringify(finalCreds, null, 2), { mode: 0o600 })

    res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' })
    res.end('<h1 style="color:green">Google Tasks authenticated.</h1><p>You can close this tab.</p>')
    console.log(`Saved credentials to ${tasksCredsPath}`)
    setTimeout(() => server.close(() => process.exit(0)), 500)
  } catch (err) {
    res.writeHead(500, { 'Content-Type': 'text/html; charset=utf-8' })
    res.end(`<h1>Auth helper error</h1><pre>${String(err)}</pre>`)
    console.error(err)
  }
})

server.listen(port, '127.0.0.1', () => {
  console.log(`Google Tasks auth helper listening on ${redirectUri}`)
  console.log(`Open this URL if your browser does not launch automatically:\n\n${authUrl.toString()}\n`)
  execFile('xdg-open', [authUrl.toString()], () => {})
})
