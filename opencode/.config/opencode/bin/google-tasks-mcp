#!/usr/bin/env bash
set -euo pipefail

CREDENTIALS_PATH="${HOME}/.google-mcp/credentials.json"

if [[ ! -f "${CREDENTIALS_PATH}" ]]; then
  >&2 printf 'Missing credentials file: %s\n' "${CREDENTIALS_PATH}"
  exit 1
fi

CLIENT_JSON="$(node -e 'const fs=require("fs"); const p=process.argv[1]; const data=JSON.parse(fs.readFileSync(p,"utf8")); const installed=data.installed||{}; if(!installed.client_id||!installed.client_secret){process.exit(2)}; process.stdout.write(JSON.stringify({client_id:installed.client_id, client_secret:installed.client_secret}))' "${CREDENTIALS_PATH}")"

GOOGLE_CLIENT_ID="$(node -e 'const v=JSON.parse(process.argv[1]); process.stdout.write(v.client_id)' "${CLIENT_JSON}")"
GOOGLE_CLIENT_SECRET="$(node -e 'const v=JSON.parse(process.argv[1]); process.stdout.write(v.client_secret)' "${CLIENT_JSON}")"

export GOOGLE_CLIENT_ID
export GOOGLE_CLIENT_SECRET
export OAUTH_PORT="3000"

exec npx -y mcp-googletasks-vrob
